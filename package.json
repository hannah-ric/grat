{
  "name": "blueprint-buddy",
  "version": "4.0.0",
  "description": "AI-guided parametric furniture design studio and workshop companion — chat proposes intent, code owns the geometry",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node serve.js",
    "build": "node build.js",
    "start": "node serve.js --no-watch",
    "test": "node test/unit.test.js && node test/audit.test.js && node test/golden.test.js && node test/battery.js && node test/server.test.js",
    "test:battery": "node test/battery.js",
    "test:server": "node test/server.test.js",
    "test:handcalc": "node test/handcalc.js",
    "test:smoke": "node build.js && node test/smoke.playwright.js",
    "test:porch": "node build.js && node test/porch.playwright.js",
    "test:cloud": "node build.js && node test/cloud.playwright.js",
    "verify": "node --env-file-if-exists=/vercel/share/.env.project scripts/verify-production.js"
  },
  "devDependencies": {
    "playwright": "^1.49.1"
  }
}
