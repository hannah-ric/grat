# Blueprint Buddy — server-side configuration, consumed by api/chat.js.
# Local dev: copy to .env (serve.js reads it automatically).
# Vercel / v0: set these in Vercel Project Settings → Environment Variables
# instead — see DEPLOYMENT.md. Never commit a real key.

# Required for AI chat + photo-to-design. Server-side only; the browser talks
# to the same-origin /api/chat proxy and never sees this key. Without it the
# app still works fully via the built-in offline intent parser.
ANTHROPIC_API_KEY=

# Optional: override the model the proxy calls (default: claude-sonnet-5).
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional: per-user monthly output-token ceiling on /api/chat (0/unset =
# disabled). A durable KV meter; trips as a 429 the client surfaces
# gracefully. Example: 750000.
# AI_MONTHLY_TOKEN_BUDGET=

# ---- Accounts + cloud persistence (all optional — see DEPLOYMENT.md) ----
# Without any of these the app persists to the browser (localStorage) and
# hides the sign-in UI entirely. With them, projects follow the user.

# Session signing secret (openssl rand -hex 32). Required for any login.
# Generate with: openssl rand -hex 32
# On Vercel this is stored as a sensitive (encrypted) var and is NOT written
# to .env by `vercel env pull` — it is confirmed set via .vercel-env-manifest.json
# AUTH_SECRET=

# "Sign in with Google": OAuth client of type Web application, authorized
# redirect URI = https://YOUR-APP/api/auth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# "Sign in with GitHub": OAuth app, callback URL = https://YOUR-APP/api/auth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Cloud document store: Upstash Redis via the Vercel Marketplace injects
# KV_REST_API_URL / KV_REST_API_TOKEN automatically (Upstash-native names
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN also work). Local dev
# needs none of this — serve.js stores documents in .data/kv.json.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Local one-click fake login for development (never set in production).
# BB_DEV_LOGIN=1

# Canonical origin for OAuth redirect URIs + Stripe success/cancel URLs.
# Recommended in production: when unset it is derived from the request Host
# header; setting it makes redirect targets immune to a spoofed Host.
# APP_ORIGIN=https://your-app.com

# ---- Stripe subscriptions (Free + Pro) ----
# Added automatically by the Stripe integration. Server-side only.
# STRIPE_SECRET_KEY=
#
# Blueprint Buddy Pro prices (already created in the live Stripe account):
#   Monthly: price_1Ttv6QDmAsGr64ouadZUalOQ  ($15.00 / month)
#   Yearly:  price_1Ttv6QDmAsGr64ouvKGZa3wR  ($144.00 / year)
# On Vercel these are set via `vercel env add` — copy values from Stripe Dashboard
# if you need to re-set them locally.
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...
#
# Signing secret for POST /api/stripe-webhook (webhook registered at
# https://hannah-ric-grat.vercel.app/api/stripe-webhook, listening to
# customer.subscription.created / .updated / .deleted).
# On Vercel this is stored as a sensitive (encrypted) var — see .vercel-env-manifest.json.
# STRIPE_WEBHOOK_SECRET=whsec_...
